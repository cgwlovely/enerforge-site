{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heliovulcan.com.au/data/schemas/evidence.schema.json",
  "title": "Heliovulcan Evidence Registry",
  "type": "object",
  "required": ["project_id", "version", "updated_at", "evidence"],
  "properties": {
    "project_id": { "type": "string", "pattern": "^project_[a-z0-9_]+$" },
    "version": { "type": "string" },
    "updated_at": { "type": "string", "format": "date" },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["evidence_id", "source_title", "publisher", "source_url", "accessed_at", "supports_claims", "evidence_type", "evidence_quality"],
        "properties": {
          "evidence_id": { "type": "string", "pattern": "^EVID-[A-Z0-9-]+$" },
          "source_title": { "type": "string", "minLength": 5 },
          "publisher": { "type": "string" },
          "source_url": { "type": ["string", "null"] },
          "document_date": { "type": "string" },
          "accessed_at": { "type": ["string", "null"], "format": "date" },
          "page_or_section": { "type": "string" },
          "supports_claims": { "type": "array", "items": { "type": "string" } },
          "evidence_type": {
            "enum": ["primary_public_document", "public_register", "company_disclosure", "reference_dataset", "published_analysis"]
          },
          "evidence_quality": { "enum": ["high", "medium", "low"] },
          "status": { "enum": ["verified", "unresolved"] },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  }
}
